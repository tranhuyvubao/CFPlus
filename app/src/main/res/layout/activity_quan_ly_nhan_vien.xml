<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_screen_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/round_background_3"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="← Tro ve"
        android:textColor="@color/coffee_primary_dark"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/app_card_background"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvTitleStaff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quan ly nhan vien"
            android:textColor="@color/coffee_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tao tai khoan, khoa mo nhan vien va theo doi thong tin co ban."
            android:textColor="@color/coffee_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnAddStaff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_background_3"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="Tao nhan vien"
            android:textColor="@color/coffee_primary_dark"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEmptyStaff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_background_3"
            android:gravity="center"
            android:padding="16dp"
            android:text="Chua co nhan vien nao."
            android:textColor="@color/coffee_muted"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvStaff"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

</LinearLayout>
