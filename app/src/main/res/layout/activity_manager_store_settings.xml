<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollStoreSettings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/manager_back_chip"
            android:elevation="3dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="Trở về"
            android:textColor="@color/dashboard_primary"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/dashboard_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thiết lập cửa hàng"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Quản lý thương hiệu, logo, thông tin liên hệ và chi nhánh."
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/dashboard_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="7dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thương hiệu"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgStoreLogo"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/manager_image_surface"
                    android:padding="14dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/cfplus4" />

                <TextView
                    android:id="@+id/btnChooseLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/manager_accent_pill"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Chọn logo"
                    android:textColor="@color/dashboard_accent"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtStoreName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Tên thương hiệu"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <EditText
                    android:id="@+id/edtStoreTagline"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Slogan / mô tả ngắn"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <EditText
                    android:id="@+id/edtStoreEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Email liên hệ"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <TextView
                    android:id="@+id/tvDefaultBranch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Chi nhánh mặc định: main"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSaveStoreProfile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/manager_primary_pill"
                    android:gravity="center"
                    android:text="Lưu thông tin cửa hàng"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/dashboard_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="7dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chi nhánh"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnAddBranch"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:background="@drawable/manager_primary_pill"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="Thêm"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBranchSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0 chi nhánh"
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/layoutBranches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
