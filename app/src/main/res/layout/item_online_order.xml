<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/dashboard_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvMaDon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mã đơn"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBanOnline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/manager_soft_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:text="Bàn"
            android:textColor="@color/dashboard_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTrangThai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Trạng thái"
            android:textColor="@color/dashboard_text_secondary" />

        <TextView
            android:id="@+id/tvNewItemsAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/manager_accent_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="Khách vừa thêm món"
            android:textColor="@color/dashboard_accent"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTongTien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tổng tiền"
            android:textColor="@color/dashboard_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChiTietMon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/manager_search_background"
            android:padding="12dp"
            android:text="Chi tiết món"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvThoiGian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Thời gian"
            android:textColor="@color/dashboard_text_secondary" />

        <TextView
            android:id="@+id/tvDiaChiGiao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Địa chỉ giao"
            android:textColor="@color/dashboard_text_secondary"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSuaDon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/manager_back_chip"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="9dp"
                android:text="Sửa đơn"
                android:textColor="@color/dashboard_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHanhDong"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/manager_primary_pill"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="9dp"
                android:text="Xác nhận"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvInBill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/manager_accent_pill"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="9dp"
                android:text="In bill"
                android:textColor="@color/dashboard_accent"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
