<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/app_card_background"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvMaDon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mã đơn"
        android:textColor="@color/coffee_dark"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvBanOnline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Bàn"
        android:textColor="@color/coffee_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTrangThai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Trạng thái"
        android:textColor="@color/coffee_muted" />

    <TextView
        android:id="@+id/tvTongTien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tổng tiền"
        android:textColor="@color/coffee_muted" />

    <TextView
        android:id="@+id/tvChiTietMon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Chi tiết món"
        android:textColor="@color/coffee_dark"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvThoiGian"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Thời gian"
        android:textColor="@color/coffee_muted" />

    <TextView
        android:id="@+id/tvDiaChiGiao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Địa chỉ giao"
        android:textColor="@color/coffee_muted"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvHanhDong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/rounded_background"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:text="Xác nhận"
        android:textColor="@color/coffee_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvInBill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_background"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:text="In bill demo"
        android:textColor="@color/coffee_warning"
        android:textStyle="bold" />

</LinearLayout>
