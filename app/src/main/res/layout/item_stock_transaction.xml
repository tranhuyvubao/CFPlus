<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/app_card_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTxnType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loại"
        android:textColor="@color/coffee_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTxnIngredient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Nguyên liệu"
        android:textColor="@color/coffee_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvTxnQty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Số lượng"
        android:textColor="@color/coffee_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvTxnTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Thời gian"
        android:textColor="@color/coffee_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvTxnNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ghi chú"
        android:textColor="@color/coffee_primary"
        android:textSize="14sp" />

</LinearLayout>
