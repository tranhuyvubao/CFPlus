<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/app_card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/imgCartItem"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/rounded_background"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:src="@drawable/cfplus" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCartItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/coffee_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCartItemVariant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/coffee_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCartItemNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/coffee_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCartItemLineTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/coffee_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnDecreaseQty"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/app_button_secondary"
            android:gravity="center"
            android:text="-"
            android:textColor="@color/coffee_primary_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCartItemQty"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/coffee_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnIncreaseQty"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/app_button_secondary"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/coffee_primary_dark"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
