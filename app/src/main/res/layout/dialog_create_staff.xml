<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dashboard_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtStaffEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/manager_search_background"
            android:hint="Email nhân viên"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtStaffPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/manager_search_background"
            android:hint="Mật khẩu (>= 6 ký tự)"
            android:inputType="textPassword"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtStaffFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/manager_search_background"
            android:hint="Họ tên nhân viên (tùy chọn)"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtStaffPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/manager_search_background"
            android:hint="SĐT (tùy chọn)"
            android:paddingHorizontal="14dp" />
    </LinearLayout>
</ScrollView>
