<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/manager_back_chip"
        android:elevation="3dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="9dp"
        android:text="Trở về"
        android:textColor="@color/dashboard_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/dashboard_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="7dp"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Nhận đơn tại bàn"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/staffTablesContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1" />

</LinearLayout>
