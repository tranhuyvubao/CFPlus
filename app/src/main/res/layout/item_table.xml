<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/dashboard_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTableName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bàn"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTableCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/manager_soft_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:text="Mã bàn"
            android:textColor="@color/dashboard_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTableArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Khu vực"
            android:textColor="@color/dashboard_text_secondary" />

        <TextView
            android:id="@+id/tvTableStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Trạng thái"
            android:textColor="@color/dashboard_text_secondary" />

        <TextView
            android:id="@+id/tvTableActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Đang sử dụng"
            android:textColor="@color/dashboard_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnTableQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/manager_soft_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="QR"
                android:textColor="@color/dashboard_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnTableEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/manager_accent_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Sửa"
                android:textColor="@color/dashboard_accent"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnTableDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/manager_danger_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Xóa"
                android:textColor="@color/dashboard_danger"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
