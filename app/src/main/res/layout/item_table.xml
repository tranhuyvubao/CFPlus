<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/app_card_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTableName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ban"
        android:textColor="@color/coffee_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTableCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ma ban"
        android:textColor="@color/coffee_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTableArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Khu vuc"
        android:textColor="@color/coffee_muted" />

    <TextView
        android:id="@+id/tvTableStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Trang thai"
        android:textColor="@color/coffee_muted" />

    <TextView
        android:id="@+id/tvTableActive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Dang su dung"
        android:textColor="@color/coffee_muted" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnTableQr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_background"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="8dp"
            android:text="QR"
            android:textColor="@color/coffee_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTableEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/rounded_background"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="8dp"
            android:text="Sua"
            android:textColor="@color/coffee_warning"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTableDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/rounded_background"
            android:paddingLeft="12dp"
            android:paddingTop="8dp"
            android:paddingRight="12dp"
            android:paddingBottom="8dp"
            android:text="Xoa"
            android:textColor="@color/coffee_danger"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
