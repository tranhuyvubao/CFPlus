<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/app_card_background"
    android:gravity="center"
    android:minHeight="112dp"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvStaffTableName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Ban 1"
        android:textColor="@color/coffee_dark"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStaffTableStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/rounded_background"
        android:paddingLeft="10dp"
        android:paddingTop="6dp"
        android:paddingRight="10dp"
        android:paddingBottom="6dp"
        android:text="Trong"
        android:textColor="@color/coffee_primary_dark"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStaffTableArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Tang 1"
        android:textColor="@color/coffee_muted"
        android:textSize="13sp" />

</LinearLayout>
