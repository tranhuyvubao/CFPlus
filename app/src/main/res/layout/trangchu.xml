<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootTrangChu"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/dashboard_card"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="18dp"
            android:paddingTop="12dp"
            android:paddingRight="18dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/btnOpenSidebar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/manager_back_chip"
                android:gravity="center"
                android:text="☰"
                android:textColor="@color/dashboard_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/hinh1"
                android:layout_width="96dp"
                android:layout_height="30dp"
                android:adjustViewBounds="true"
                android:src="@drawable/cfplus2" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <FrameLayout
                android:id="@+id/btnHeaderNotifications"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/manager_back_chip"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notifications_24" />

                <TextView
                    android:id="@+id/tvHeaderNotificationBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="end|top"
                    android:background="@drawable/notification_badge_background"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/frameLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:layout_weight="1" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/app_bottom_nav_background"
            android:elevation="10dp"
            app:itemBackground="@drawable/bottom_nav_item_background"
            app:itemIconTint="@color/app_bottom_nav_item_colors"
            app:itemPaddingBottom="8dp"
            app:itemPaddingTop="10dp"
            app:itemRippleColor="@color/dashboard_nav_active_bg"
            app:itemTextColor="@color/app_bottom_nav_item_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/sideMenuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/sideMenuPanel"
            android:layout_width="220dp"
            android:layout_height="match_parent"
            android:background="@color/dashboard_card"
            android:elevation="18dp"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="48dp"
            android:paddingRight="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/tvSidebarTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CFPLUS"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSidebarSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Lối tắt nhanh"
                android:textColor="@color/dashboard_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/rowSidebarHome"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Trang chủ"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowSidebarCart"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Giỏ hàng"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowSidebarOrders"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Đơn hàng của tôi"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowSidebarChat"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Chat AI"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rowSidebarAnalytics"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Thống kê"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/rowSidebarProducts"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Quản lý món"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/rowSidebarBanners"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Slide banner"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/rowSidebarStock"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Kho nguyên liệu"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/rowSidebarStaff"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Nhân viên"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/rowSidebarStoreSettings"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/manager_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Cửa hàng &amp; chi nhánh"
                android:textColor="@color/dashboard_text_primary"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/chatBubble"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="132dp"
        android:background="@drawable/app_chat_fab_background"
        android:clickable="true"
        android:contentDescription="Mở chat AI hỗ trợ"
        android:elevation="10dp"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
