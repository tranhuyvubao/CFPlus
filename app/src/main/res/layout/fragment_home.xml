<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FragmentHome">

    <LinearLayout
        android:id="@+id/layoutMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/dashboard_background"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <SearchView
            android:id="@+id/action_search"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/manager_search_background"
            android:iconifiedByDefault="false"
            android:queryHint="Tìm cà phê, trà hoặc món bạn thích..." />

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/btnOpenCart"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/manager_back_chip"
                android:drawableStart="@drawable/baseline_shopping_cart_24"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="Giỏ hàng"
                android:textColor="@color/dashboard_primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHomeCartCount"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|top"
                android:background="@drawable/manager_primary_pill"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/btnOpenReservation"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/manager_back_chip"
            android:drawableStart="@drawable/baseline_history_24"
            android:drawablePadding="6dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="Đặt bàn"
            android:textColor="@color/dashboard_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
        </LinearLayout>

        <HorizontalScrollView
        android:id="@+id/bannerScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layoutPromoBanners"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
        android:id="@+id/tvSearchEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/manager_search_background"
        android:gravity="center"
        android:padding="18dp"
        android:text="Không tìm thấy món phù hợp."
        android:textColor="@color/dashboard_text_secondary"
        android:textSize="15sp"
        android:visibility="gone" />

        <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

        <ListView
        android:id="@+id/lvSearch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:paddingBottom="12dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnFloatingSupportChat"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="92dp"
        android:background="@drawable/app_chat_fab_background"
        android:drawableTop="@drawable/baseline_note_alt_24"
        android:elevation="8dp"
        android:gravity="center"
        android:paddingTop="7dp"
        android:text="Chat"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold" />
</FrameLayout>
