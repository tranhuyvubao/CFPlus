<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dashboard_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/edtPromoCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/manager_search_background"
            android:hint="Mã giảm giá (VD: SALE10)"
            android:minHeight="52dp"
            android:paddingHorizontal="14dp" />

        <Spinner
            android:id="@+id/spPromoType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtPromoValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/manager_search_background"
            android:hint="Giá trị giảm"
            android:inputType="number"
            android:minHeight="52dp"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtPromoMinOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/manager_search_background"
            android:hint="Đơn tối thiểu"
            android:inputType="number"
            android:minHeight="52dp"
            android:paddingHorizontal="14dp" />

        <EditText
            android:id="@+id/edtPromoMaxDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/manager_search_background"
            android:hint="Giảm tối đa (nếu theo %)"
            android:inputType="number"
            android:minHeight="52dp"
            android:paddingHorizontal="14dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swPromoHasLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Có thời hạn"
            android:textColor="@color/dashboard_text_primary" />

        <LinearLayout
            android:id="@+id/layoutPromoDateRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edtPromoStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/manager_search_background"
                android:clickable="true"
                android:focusable="false"
                android:hint="Ngày bắt đầu"
                android:inputType="none"
                android:minHeight="52dp"
                android:paddingHorizontal="14dp" />

            <EditText
                android:id="@+id/edtPromoEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/manager_search_background"
                android:clickable="true"
                android:focusable="false"
                android:hint="Ngày kết thúc"
                android:inputType="none"
                android:minHeight="52dp"
                android:paddingHorizontal="14dp" />
        </LinearLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swPromoActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Kích hoạt"
            android:textColor="@color/dashboard_text_primary" />
    </LinearLayout>
</ScrollView>
