<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/coffee_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvMyOrderId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đơn:"
            android:textColor="@color/coffee_dark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMyOrderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Trang thai:"
            android:textColor="@color/coffee_muted" />

        <TextView
            android:id="@+id/tvMyOrderTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tong:"
            android:textColor="@color/coffee_primary" />

        <TextView
            android:id="@+id/tvMyOrderTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tao luc:"
            android:textColor="@color/coffee_muted" />

        <TextView
            android:id="@+id/tvMyOrderItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mon:"
            android:layout_marginTop="8dp"
            android:textColor="@color/coffee_text" />

        <TextView
            android:id="@+id/btnPayMyOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thanh toan ngay"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:padding="10dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_color" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

