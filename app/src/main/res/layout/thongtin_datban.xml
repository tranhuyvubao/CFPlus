<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/app_screen_background"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/app_card_background"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/thongtin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Thong tin tao don"
                android:textColor="@color/coffee_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/luuy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Nhap day du ban, hinh thuc, so dien thoai va nhan vien de don duoc luu chinh xac."
                android:textColor="@color/coffee_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tenban"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Ban / khu vuc"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editban"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:hint="Vi du: Ban 01"
                android:inputType="text"
                android:padding="12dp"
                android:textColor="@color/coffee_dark"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:id="@+id/tvhinh_thuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Hinh thuc"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgHinhThuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/tai_cho"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/coffee_primary"
                    android:checked="true"
                    android:text="Tai cho"
                    android:textColor="@color/coffee_dark" />

                <RadioButton
                    android:id="@+id/mang_ve"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/coffee_primary"
                    android:text="Mang ve"
                    android:textColor="@color/coffee_dark" />
            </RadioGroup>

            <TextView
                android:id="@+id/sdt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="So dien thoai khach"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editSdt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:hint="Nhap so dien thoai"
                android:inputType="phone"
                android:padding="12dp"
                android:textColor="@color/coffee_dark"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:id="@+id/tvtennv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Nhan vien phu trach"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_tennv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:hint="Nhap ten nhan vien"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:textColor="@color/coffee_dark"
                android:textColorHint="@color/coffee_muted" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvthemgiohang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_color"
            android:gravity="center"
            android:padding="15dp"
            android:text="Luu vao don"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
