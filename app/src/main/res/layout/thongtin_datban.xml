<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/thongtin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="THÔNG TIN ĐẶT BÀN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/luuy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="*Lưu ý: Nhân viên phải ghi thông tin đầy đủ gồm bàn, hình thức, số điện thoại, tên nhân viên tránh lạc mất thông tin, giao nhầm bàn khác"
            android:textColor="@color/grey"
            android:textSize="12sp"
            android:textStyle="italic" />

        <!-- Bàn -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tenban"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bàn:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editban"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:minHeight="48dp"
                android:padding="8dp"
                android:inputType="text"
                android:hint="vd: Số 1"
                android:textSize="16sp"
                android:background="@drawable/rounded_background" />

        </LinearLayout>

        <!-- Hình thức -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvhinh_thuc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Hình thức:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgHinhThuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/tai_cho"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tại chỗ"
                    android:textSize="16sp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/mang_ve"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mang về"
                    android:textSize="16sp" />

            </RadioGroup>
        </LinearLayout>

        <!-- SĐT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/sdt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SĐT:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editSdt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:minHeight="48dp"
                android:padding="8dp"
                android:inputType="phone"
                android:hint="Điền sdt của khách hàng"
                android:textSize="16sp"
                android:background="@drawable/rounded_background" />

        </LinearLayout>

        <!-- Tên nhân viên -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvtennv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tên nhân viên:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edit_tennv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:minHeight="48dp"
                android:padding="8dp"
                android:inputType="textPersonName"
                android:hint="vd: Nguyễn Văn A"
                android:textSize="16sp"
                android:background="@drawable/rounded_background" />

        </LinearLayout>

        <!-- Nút thêm vào giỏ -->
        <TextView
            android:id="@+id/tvthemgiohang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:background="@drawable/bg_color_2"
            android:text="Thêm thông tin đặt bàn"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
