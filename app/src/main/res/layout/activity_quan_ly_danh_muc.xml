<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_screen_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/round_background_3"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:text="← Trở về"
        android:textColor="@color/coffee_primary_dark"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/app_card_background"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quản lý danh mục"
            android:textColor="@color/coffee_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tổ chức menu theo nhóm để quản lý món và tìm kiếm dễ hơn."
            android:textColor="@color/coffee_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnAddCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_background_3"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:text="Thêm danh mục"
            android:textColor="@color/coffee_primary_dark"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtSearchCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_background"
            android:hint="Tìm danh mục theo tên"
            android:padding="12dp"
            android:textColor="@color/coffee_dark"
            android:textColorHint="@color/coffee_muted" />

        <TextView
            android:id="@+id/tvEmptyCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/round_background_3"
            android:gravity="center"
            android:padding="16dp"
            android:text="Chưa có danh mục nào."
            android:textColor="@color/coffee_muted"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

</LinearLayout>
