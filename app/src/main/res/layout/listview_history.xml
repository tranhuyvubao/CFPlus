<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:elevation="4dp"
    app:cardCornerRadius="12dp">

    <!-- Khối ngang chia 2 phần -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Cột 1: ảnh sản phẩm -->
        <ImageButton
            android:id="@+id/imageButton1"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_vertical"
            android:background="@null"
            android:clickable="false"
            android:contentDescription="@string/anh_san_pham"
            android:focusable="false"
            android:scaleType="centerCrop" />

        <!-- Cột 2: thông tin sản phẩm -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tenban"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên bàn:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên sản phẩm:"
                android:textColor="#304FFE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGiamGia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giảm giá:"
                android:textColor="#999999"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Size:"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvmucda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mức đá:"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvslsp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số lượng:"
                android:textColor="#666" />

            <TextView
                android:id="@+id/tvGia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng tiền: "
                android:textColor="#03A9F4"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvhinhthuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hình thức:"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvtrangthai_thanhtoan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Trạng thái: Chưa thanh toán"
                android:textColor="#DD2C00"
                android:textSize="16sp"
                android:textStyle="normal|bold" />
        </LinearLayout>

        <!-- Cột 3: nút sửa và xóa -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/baseline_edit_square_24"
                android:drawablePadding="4dp"
                android:text="Sửa"
                android:gravity="center"
                android:textColor="#FF9900"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/deleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableTop="@drawable/baseline_delete_24"
                android:drawablePadding="4dp"
                android:text="Xóa"
                android:gravity="center"
                android:textColor="#FF0000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
