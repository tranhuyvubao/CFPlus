<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/app_chip_accent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="14dp"
            android:paddingTop="10dp"
            android:paddingRight="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="@color/coffee_primary_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Trở về"
                android:textColor="@color/coffee_primary_dark"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/app_card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cấu hình VNPAY sandbox"
                android:textColor="@color/coffee_dark"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Lưu TMN code, hash secret và return URL để dùng thử luồng thanh toán VNPAY sandbox ngay trong app."
                android:textColor="@color/coffee_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="TMN code"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtVnpayTmnCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:hint="Ví dụ: ABCDEF12"
                android:inputType="textVisiblePassword"
                android:padding="14dp"
                android:textColor="@color/coffee_dark"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Hash secret"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtVnpayHashSecret"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:hint="Dán hash secret sandbox"
                android:inputType="textVisiblePassword"
                android:padding="14dp"
                android:textColor="@color/coffee_dark"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Return URL"
                android:textColor="@color/coffee_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtVnpayReturnUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:hint="Ví dụ: cfplus://vnpay-return"
                android:inputType="textUri"
                android:padding="14dp"
                android:textColor="@color/coffee_primary_dark"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Lưu ý: đây là cấu hình demo sandbox. Khi triển khai thật, chữ ký VNPAY nên được tạo ở backend thay vì trong app."
                android:textColor="@color/coffee_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnClearVnpayConfig"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/app_button_secondary"
                    android:gravity="center"
                    android:paddingLeft="14dp"
                    android:paddingTop="14dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="14dp"
                    android:text="Xóa cấu hình"
                    android:textColor="@color/coffee_primary_dark"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnSaveVnpayConfig"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/app_button_primary"
                    android:gravity="center"
                    android:paddingLeft="14dp"
                    android:paddingTop="14dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="14dp"
                    android:text="Lưu cấu hình"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
