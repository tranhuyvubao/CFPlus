<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dashboard_card"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/edtCustomerName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/manager_search_background"
        android:hint="Họ tên"
        android:minHeight="52dp"
        android:paddingHorizontal="14dp"
        android:textColor="@color/dashboard_text_primary"
        android:textColorHint="@color/dashboard_text_secondary" />

    <EditText
        android:id="@+id/edtCustomerPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/manager_search_background"
        android:hint="Số điện thoại"
        android:minHeight="52dp"
        android:paddingHorizontal="14dp"
        android:textColor="@color/dashboard_text_primary"
        android:textColorHint="@color/dashboard_text_secondary" />

    <EditText
        android:id="@+id/edtCustomerEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/manager_search_background"
        android:hint="Email"
        android:minHeight="52dp"
        android:paddingHorizontal="14dp"
        android:textColor="@color/dashboard_text_primary"
        android:textColorHint="@color/dashboard_text_secondary" />
</LinearLayout>
