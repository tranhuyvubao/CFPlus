<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/app_card_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgBillProduct"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/app_chip_accent"
            android:padding="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/cfplus4" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1.7"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBillProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên món"
                android:textColor="@color/coffee_dark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBillNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Ghi chú"
                android:textColor="@color/coffee_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBillQty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.7"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/coffee_dark" />

        <TextView
            android:id="@+id/tvBillUnitPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="center"
            android:text="25.000đ"
            android:textColor="@color/coffee_dark" />

        <TextView
            android:id="@+id/tvBillLineTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="25.000đ"
            android:textColor="@color/coffee_primary_dark"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
