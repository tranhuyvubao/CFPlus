<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="@color/dashboard_card"
    app:cardCornerRadius="20dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvReservationCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khách hàng"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReservationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/manager_accent_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:text="Đang chờ khách"
            android:textColor="@color/dashboard_accent"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReservationTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Bàn: Bàn 1"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvReservationTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Giờ đến: 09/04/2026 18:30"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvReservationGuests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Số khách: 4"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvReservationPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Điện thoại: 0900000000"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvReservationNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ghi chú: Không có"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnReservationConfirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/manager_primary_pill"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Xác nhận đến"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnReservationCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:background="@drawable/manager_back_chip"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Hủy"
                android:textColor="@color/dashboard_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnReservationComplete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:background="@drawable/manager_back_chip"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:text="Hoàn tất"
                android:textColor="@color/dashboard_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
