<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/manager_back_chip"
            android:elevation="3dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:text="Trở về"
            android:textColor="@color/dashboard_primary"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/dashboard_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="7dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gọi món tại bàn"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Nhập hoặc quét mã bàn để gửi món về đúng bàn."
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtTableCode"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Mã bàn (ví dụ: BAN01)"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <TextView
                    android:id="@+id/btnScanTableQr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/manager_back_chip"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Quét QR bàn"
                    android:textColor="@color/dashboard_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtTenMon"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Tên món"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <TextView
                    android:id="@+id/btnChonMonTuMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/manager_back_chip"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Chọn món từ menu"
                    android:textColor="@color/dashboard_primary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtGiaMon"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Giá (VND)"
                    android:inputType="number"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <EditText
                    android:id="@+id/edtSoLuongMon"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Số lượng"
                    android:inputType="number"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <EditText
                    android:id="@+id/edtSizeMon"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Size (S/M/L - tùy chọn)"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <EditText
                    android:id="@+id/edtGhiChuMon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Ghi chú (ít đá, ít đường...)"
                    android:minLines="2"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <EditText
                    android:id="@+id/edtImageUrlMon"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/manager_search_background"
                    android:hint="Đường dẫn ảnh (tùy chọn)"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <TextView
                    android:id="@+id/btnDatMonOnline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/manager_primary_pill"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="Gửi món về bàn này"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
