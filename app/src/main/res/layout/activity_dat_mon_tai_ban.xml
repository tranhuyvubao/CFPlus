<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/round_background_3"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
        android:text="Trở về"
            android:textColor="@color/coffee_primary_dark"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/app_card_background"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
        android:text="Gọi món tại bàn"
                android:textColor="@color/coffee_dark"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Luong nay danh rieng cho khach dang ngoi tai quan. Khach nhap ma ban da quet tu QR de gui mon ve dung ban."
                android:textColor="@color/coffee_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtTableCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/rounded_background"
                android:hint="Ma ban (vi du: BAN01)"
                android:paddingHorizontal="14dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:id="@+id/btnScanTableQr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/round_background_3"
                android:gravity="center"
                android:padding="12dp"
                android:text="Quet QR ban"
                android:textColor="@color/coffee_primary_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtTenMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_background"
                android:hint="Ten mon"
                android:paddingHorizontal="14dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:id="@+id/btnChonMonTuMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/round_background_3"
                android:gravity="center"
                android:padding="12dp"
                android:text="Chon mon tu menu"
                android:textColor="@color/coffee_primary_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtGiaMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_background"
                android:hint="Gia (VND)"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <EditText
                android:id="@+id/edtSoLuongMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_background"
                android:hint="So luong"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <EditText
                android:id="@+id/edtSizeMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_background"
                android:hint="Size (S/M/L - tuy chon)"
                android:paddingHorizontal="14dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <EditText
                android:id="@+id/edtGhiChuMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_background"
                android:hint="Ghi chu (it da, it duong...)"
                android:minLines="2"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <EditText
                android:id="@+id/edtImageUrlMon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_background"
                android:hint="Duong dan anh (tuy chon)"
                android:paddingHorizontal="14dp"
                android:textColor="@color/coffee_text"
                android:textColorHint="@color/coffee_muted" />

            <TextView
                android:id="@+id/btnDatMonOnline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_color"
                android:gravity="center"
                android:padding="14dp"
                android:text="Gui mon ve ban nay"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
