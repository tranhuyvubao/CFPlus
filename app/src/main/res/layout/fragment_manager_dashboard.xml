<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="18dp"
        android:paddingRight="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDashboardSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Chào buổi sáng, quản lý"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:minHeight="156dp"
            app:cardBackgroundColor="@color/dashboard_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="22dp">

                <ImageView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/dashboard_icon_circle_primary"
                    android:padding="14dp"
                    android:src="@drawable/ic_dashboard_revenue_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="DOANH THU HÔM NAY"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvManagerMetricRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0đ"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cập nhật theo đơn đã thanh toán"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Tổng quan hôm nay"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="132dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_marginEnd="7dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/dashboard_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/dashboard_icon_circle_primary"
                        android:padding="9dp"
                        android:src="@drawable/ic_dashboard_receipt_24" />

                    <TextView
                        android:id="@+id/tvManagerMetricPaidOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đơn đã thanh toán"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="132dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_marginStart="7dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/dashboard_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/dashboard_icon_circle_primary"
                        android:padding="9dp"
                        android:src="@drawable/ic_dashboard_staff_24" />

                    <TextView
                        android:id="@+id/tvManagerMetricStaff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhân viên"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="132dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_marginEnd="7dp"
                app:cardBackgroundColor="@color/dashboard_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/dashboard_icon_circle_accent"
                        android:padding="9dp"
                        android:src="@drawable/ic_dashboard_offer_24" />

                    <TextView
                        android:id="@+id/tvManagerMetricPromo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/dashboard_text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã khuyến mãi"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="132dp"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_marginStart="7dp"
                app:cardBackgroundColor="@color/dashboard_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/dashboard_icon_circle_accent"
                        android:padding="9dp"
                        android:src="@drawable/ic_dashboard_inventory_24" />

                    <TextView
                        android:id="@+id/tvManagerMetricStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="@color/dashboard_accent"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sắp hết hàng"
                        android:textColor="@color/dashboard_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Quản lý nhanh"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:useDefaultMargins="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardThongKeHomNay"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_today" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardThongKeTongHop"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_analytics" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyMon"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_products" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyDanhMuc"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_categories" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyBan"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_tables" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyKho"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_stock" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyKhuyenMai"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_promo" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyNhanVien"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_staff" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuanLyKhachHang"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_customers" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBarMode"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_bar" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActionLogs"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_logs" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVnpaySandbox"
                style="@style/DashboardActionTile">
                <include layout="@layout/include_dashboard_action_payment" />
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

    </LinearLayout>
</ScrollView>
