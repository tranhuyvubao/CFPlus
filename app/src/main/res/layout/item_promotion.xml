<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/dashboard_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvPromoCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/manager_accent_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:text="Code"
            android:textColor="@color/dashboard_accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPromoTypeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Giảm"
            android:textColor="@color/dashboard_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPromoRule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Rule"
            android:textColor="@color/dashboard_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPromoActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/manager_soft_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:text="Trạng thái"
            android:textColor="@color/dashboard_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPromoEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/manager_accent_pill"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Sửa"
                android:textColor="@color/dashboard_accent"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnPromoDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/manager_danger_pill"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Xóa"
                android:textColor="@color/dashboard_danger"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
