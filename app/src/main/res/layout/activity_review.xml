<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/manager_back_chip"
            android:elevation="3dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:text="Trở về"
            android:textColor="@color/dashboard_primary"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/dashboard_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="7dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đánh giá đơn hàng"
                    android:textColor="@color/dashboard_text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Chia sẻ trải nghiệm để quán phục vụ bạn tốt hơn."
                    android:textColor="@color/dashboard_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvReviewItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/manager_search_background"
                    android:padding="12dp"
                    android:text="Món trong đơn"
                    android:textColor="@color/dashboard_text_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/star1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:text="★"
                        android:textColor="@color/dashboard_accent"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/star2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:text="★"
                        android:textColor="@color/dashboard_accent"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/star3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:text="★"
                        android:textColor="@color/dashboard_accent"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/star4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:text="★"
                        android:textColor="@color/dashboard_accent"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/star5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:text="★"
                        android:textColor="@color/dashboard_accent"
                        android:textSize="32sp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/edtReviewComment"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/manager_search_background"
                    android:gravity="top|start"
                    android:hint="Chia sẻ cảm nhận về món, phục vụ, giao hàng..."
                    android:inputType="textMultiLine"
                    android:padding="14dp"
                    android:textColor="@color/dashboard_text_primary"
                    android:textColorHint="@color/dashboard_text_secondary" />

                <LinearLayout
                    android:id="@+id/cardReviewImagePlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/manager_accent_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/baseline_info_outline_24"
                        android:tint="@color/dashboard_accent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Thêm ảnh review sẽ được nối tiếp khi bật storage."
                        android:textColor="@color/dashboard_text_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnSubmitReview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/manager_primary_pill"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="Gửi đánh giá"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
