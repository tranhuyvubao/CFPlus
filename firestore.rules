rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Demo rules for CFPLUS:
    // - app currently uses Firebase anonymous auth
    // - business data is Firebase-first
    // - tighten later when role-based auth/claims are added

    match /tables/{tableId} {
      allow read, write: if request.auth != null;
    }

    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;

      match /favorites/{productId} {
        allow read, write: if request.auth != null;
      }
    }

    match /customer_profiles/{profileId} {
      allow read, write: if request.auth != null;
    }

    match /customer_addresses/{addressId} {
      allow read, write: if request.auth != null;
    }

    match /categories/{categoryId} {
      allow read, write: if request.auth != null;
    }

    match /products/{productId} {
      allow read, write: if request.auth != null;
    }

    match /ingredients/{ingredientId} {
      allow read, write: if request.auth != null;
    }

    match /promotions/{promotionId} {
      allow read, write: if request.auth != null;
    }

    match /promo_banners/{bannerId} {
      allow read, write: if request.auth != null;
    }

    match /store_profiles/{profileId} {
      allow read, write: if request.auth != null;
    }

    match /store_branches/{branchId} {
      allow read, write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read, write: if request.auth != null;
    }

    match /table_reservations/{reservationId} {
      allow read, write: if request.auth != null;
    }

    match /stock_transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
